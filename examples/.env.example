# AgentTrace — .env.example
#
# Copy this file to .env in the same directory and fill in your values.
#
#   cp .env.example .env
#
# Then edit .env — it is gitignored and never committed.

# ── Groq API ─────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com/
GROQ_API_KEY=your_key_here

# ── AgentTrace server (optional) ─────────────────────────────────────────────
# Override if your server is not running on localhost:8000
# AGENTTRACE_SERVER_URL=http://localhost:8000
